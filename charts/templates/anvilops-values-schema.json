{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/PurdueRCAC/AnvilOps/refs/heads/main/charts/templates/anvilops-values-schema.json",
  "title": "anvilops-values",
  "description": "The schema for anvilops-values objects in Chart.yaml",
  "type": "object",
  "$ref": "#/$defs/branch",
  "$defs": {
    "branch": {
      "type": "object",
      "properties": {
        "_anvilopsRender": {
          "type": "object",
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "const": "section"
                },
                "displayName": {
                  "type": "string"
                }
              },
              "required": ["type", "displayName"]
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "const": "dropdown"
                }
              }
            }
          ]
        },
        "children": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "$ref": "#/$defs/branch"
              },
              {
                "$ref": "#/$defs/leaf"
              }
            ]
          }
        }
      },
      "required": ["_anvilopsRender", "children"]
    },
    "leaf": {
      "type": "object",
      "description": "A value for a key in the values.yaml",
      "properties": {
        "_anvilopsValue": {
          "const": true
        },
        "displayName": {
          "type": "string"
        },
        "type": {
          "enum": ["text", "number"]
        },
        "required": {
          "type": "boolean"
        },
        "random": {
          "type": "boolean"
        },
        "default": {},
        "noUpdate": {
          "type": "boolean"
        },
        "unit": {
          "type": "string"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "additionalProperties": false,
      "required": ["_anvilopsValue", "displayName", "type", "required"]
    }
  }
}
